# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/autodealer
REDIS_URL=redis://redis:6379/0

# Admin
ADMIN_PASSWORD=
DEFAULT_DEALERSHIP_ID=1

# OpenAI (optional — system works fully without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_ENABLED=false

# WhatsApp Business Cloud API (optional — test chat works without it)
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# MercadoLibre (optional — test chat works without it)
ML_ACCESS_TOKEN=
ML_USER_ID=

# Notifications (optional)
MANAGER_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=

# Security (Phase 2)
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
ADMIN_PASSWORD_HASH=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Bot behavior
FOLLOWUPS_ENABLED=false
DEFAULT_LANGUAGE=es-AR
FALLBACK_LANGUAGE=en
