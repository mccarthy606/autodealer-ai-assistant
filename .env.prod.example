# AutoDealer AI Assistant — Production Environment
# Copy to .env.prod and fill in all values before first deploy.
# cp .env.prod.example .env.prod

# Database (postgres service connects using POSTGRES_* vars; app uses DATABASE_URL)
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/autodealer

# Redis
REDIS_URL=redis://redis:6379/0

# PostgreSQL credentials (used by the postgres service itself)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=autodealer

# WhatsApp Business Cloud API
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# MercadoLibre
ML_ACCESS_TOKEN=
ML_USER_ID=

# Lemon Squeezy Billing
LEMON_SQUEEZY_WEBHOOK_SECRET=

# MercadoLibre webhook secret (optional — set if ML provides a signing secret)
ML_WEBHOOK_SECRET=

# Admin UI (generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())")
ADMIN_PASSWORD_HASH=

# OpenAI
OPENAI_API_KEY=

# Security
ALLOWED_ORIGINS=https://yourdomain.com
# Set SESSION_COOKIE_SECURE=false only for local HTTP development (never in production)
SESSION_COOKIE_SECURE=true

# Sentry Error Monitoring (leave empty to disable)
# Credential encryption (required in production)
CREDENTIAL_ENCRYPTION_KEY=  # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Follow-up Automation (set true once WhatsApp templates are Meta-approved)
FOLLOWUPS_ENABLED=false

# App defaults
DEFAULT_DEALERSHIP_ID=1
